# ==== 宿主机端口映射（避开常见冲突；如果还冲突就再改）====
BACKEND_HOST_PORT=18000
POSTGRES_HOST_PORT=25432
MINIO_HOST_PORT=19000
MINIO_CONSOLE_HOST_PORT=19001

# ==== 默认：完全本地 mock 模式（零云依赖、零 API key、零模型权重）====
# 切换到真 ASR/LLM 时把 mock 改成 dashscope / api
ASR_BACKEND=dashscope
LLM_BACKEND=api

# ==== 存储后端：local / minio / oss ====
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=/data/recordings
# 注意：端口要和上面 BACKEND_HOST_PORT 保持一致；ASR / Web 端在线试听靠这个 base
LOCAL_STORAGE_PUBLIC_BASE=http://localhost:18000
RECORDING_SIGN_SECRET=change-me-to-a-long-random-string

# ---- MinIO（仅 STORAGE_BACKEND=minio 时用到）----
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_dev
MINIO_BUCKET=recordings
MINIO_PUBLIC_HOST=localhost:19000

# ---- 阿里云 OSS（仅 STORAGE_BACKEND=oss 时用到）----
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=
OSS_USE_SIGNED_URL=true
OSS_SIGNED_URL_EXPIRES_SEC=3600

# ==== ASR：阿里云 DashScope（ASR_BACKEND=dashscope 时启用）====
DASHSCOPE_API_KEY=sk-3dd8821bf3014436b20e50147123b3a8
DASHSCOPE_ASR_MODEL=paraformer-v2

# ==== LLM：OpenAI 兼容协议（LLM_BACKEND=api 时启用）====
# 选项 A）云 DeepSeek：
#   LLM_BASE_URL=https://api.deepseek.com
#   LLM_MODEL=deepseek-chat
#   LLM_API_KEY=sk-xxxx
# 选项 B）本地 Ollama（Mac 上一行命令装：brew install ollama && ollama pull qwen2.5:7b）：
#   LLM_BASE_URL=http://host.docker.internal:11434/v1
#   LLM_MODEL=qwen2.5:7b
#   LLM_API_KEY=ollama       # 任意字符串
LLM_API_KEY=sk-3dd8821bf3014436b20e50147123b3a8
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# ==== 加密（手机号 AES-256 加密）====
AUTOLUYIN_AES_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ==== 短信通道（MVP 可留空）====
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY=
SMS_ACCESS_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_PAY=
