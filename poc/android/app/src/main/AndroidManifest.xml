<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 拨号 + 通话状态监听 -->
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_PHONE_NUMBERS" />
    <uses-permission android:name="android.permission.READ_CALL_LOG" />
    <uses-permission android:name="android.permission.PROCESS_OUTGOING_CALLS" />

    <!-- 录音文件读取（MIUI/华为等录音目录在共享存储）-->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <!-- 部分 ROM 必须开 MANAGE_EXTERNAL_STORAGE 才能读到 /storage/emulated/0/MIUI/ -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- v1.9.9 — FOREGROUND_SERVICE_DATA_SYNC 是 Android 14 (API 34) 引入；
         本 App 目标 MIUI 10 (Android 8.1/9) — 老平台 PackageParser 见此未知 perm 可能解析失败。
         如果未来支持 Android 14+ 再加回，配合 tools:targetApi="34"。 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Sprint 12.4 — 二维码扫码拨号备份方案 -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:allowBackup="false"
        android:label="autoluyin-demo"
        android:theme="@style/Theme.AppCompat.DayNight.NoActionBar"
        android:usesCleartextTraffic="true">
        <!-- v1.9.9 — requestLegacyExternalStorage 是 Android 10 (API 29) 引入；
             目标 MIUI 10 (Android 8.1/9) 本身没有 scoped storage，此属性无意义且会被
             老 PackageParser 视为未知属性导致解析失败。 -->

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- v2.0 Task 2 — Compose Hybrid Shell（4 tab + WebView）。
             MainActivity 完成 preflight (权限/URL/login/self-check) 后跳入此处。 -->
        <activity
            android:name=".HomeActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.DayNight.NoActionBar" />

        <!-- v1.9.9 — foregroundServiceType 是 Android 10 (API 29) 引入的属性。
             目标平台 MIUI 10 (Android 8.1/9) 的 PackageParser 不认识此属性 → 解析失败。
             Android 8/9 上普通 foreground service 不需要 type；Android 10+ 才需要在调用
             startForeground 时配合 ServiceInfo.FOREGROUND_SERVICE_TYPE_DATA_SYNC。 -->
        <service
            android:name=".CallWatcherService"
            android:exported="false" />

        <!-- 静态注册，服务被杀后仍能收到 PHONE_STATE，确保挂机后唤醒上传 -->
        <receiver
            android:name=".PhoneStateReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.PHONE_STATE" />
            </intent-filter>
        </receiver>

        <!-- MiPush 推送接收 -->
        <receiver android:name=".push.MiPushService"
                  android:exported="true">
            <intent-filter>
                <action android:name="com.xiaomi.mipush.RECEIVE_MESSAGE" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.xiaomi.mipush.MESSAGE_ARRIVED" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.xiaomi.mipush.ERROR" />
            </intent-filter>
        </receiver>

        <!-- 实时通话界面（从锁屏唤醒）-->
        <activity android:name=".realtime.RealtimeCallActivity"
                  android:launchMode="singleTask"
                  android:showWhenLocked="true"
                  android:turnScreenOn="true"
                  android:exported="false" />

        <!-- Sprint 11.2 — 本月绩效小结 -->
        <activity android:name=".MyPerformanceActivity" android:exported="false" />

        <!-- Sprint 11.3 — 个人设置 -->
        <activity android:name=".SettingsActivity" android:exported="false" />

        <!-- Sprint 12.4 — 扫码 Activity（CameraX + ML Kit barcode）-->
        <activity android:name=".scan.QrScanActivity"
                  android:exported="false"
                  android:screenOrientation="portrait"
                  tools:ignore="LockedOrientationActivity" />

        <!-- Sprint 12.4 — autoluyin://dial deeplink 落地页 -->
        <activity android:name=".scan.DialFromQrActivity"
                  android:exported="true"
                  android:launchMode="singleTask">
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="autoluyin" android:host="dial" />
            </intent-filter>
        </activity>
    </application>
</manifest>
